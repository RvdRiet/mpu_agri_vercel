{
  "name": "farm-management",
  "version": "1.0.0",
  "description": "Mpumalanga Livestock Development Programme",
  "scripts": {
    "start": "node server.js",
    "test": "playwright test && node tests/scripts/generate-summary.js",
    "test:smoke": "playwright test tests/smoke && node tests/scripts/generate-summary.js",
    "test:functional": "playwright test tests/functional && node tests/scripts/generate-summary.js",
    "test:regression": "playwright test tests/regression && node tests/scripts/generate-summary.js",
    "test:api": "playwright test tests/api && node tests/scripts/generate-summary.js",
    "test:report": "playwright show-report test-reports/html",
    "test:summary": "node tests/scripts/generate-summary.js",
    "test:ci": "playwright test && node tests/scripts/generate-summary.js",
    "beneficiaries:import": "node scripts/convert-beneficiaries-xlsx.js"
  },
  "dependencies": {
    "@vercel/blob": "^0.27.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "xlsx": "^0.18.5"
  }
}
