# Staff analytics API (set in Vercel project settings or .env for local dev)
STAFF_API_SECRET=change-me-to-a-long-random-string
STAFF_USERS={"admin":{"password":"change-me","name":"Admin"}}

# Optional: persist monthly analytics on Vercel (Blob store)
# BLOB_READ_WRITE_TOKEN=

# ----------------------------------------------------------------------------
# Database (PostgreSQL) — required for /api/auth/* and /api/applications
# ----------------------------------------------------------------------------
# Connection string. Examples:
#   Local:   postgresql://postgres:postgres@localhost:5432/agrisupport
#   Hosted:  postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# Set to "true" for hosted Postgres that requires TLS (Neon, Supabase, Azure).
# Leave "false" for a local server without SSL.
DATABASE_SSL=false

# Max pooled connections. Keep small on serverless (e.g. 5).
PG_POOL_MAX=5

# Secret used to sign applicant session tokens and hash SA ID numbers.
# Use a long random string. Falls back to STAFF_API_SECRET if unset.
AUTH_SECRET=change-me-to-a-long-random-string
